# --- Service ---
SERVICE_NAME=stackai-agent-runs
DATABASE_URL=sqlite+aiosqlite:///./agent_runs.db

# --- Runner ---
# Divides simulated latency (ms) by this factor so demo runs finish fast.
# Set to 1 for "realistic" timing.
RUNNER_SPEED_FACTOR=20
RUNNER_FAILURE_RATE=0.15

# --- OpenTelemetry ---
# Default: local collector -> Jaeger, started by docker-compose.yml
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=

# To point at Honeycomb instead, set:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_API_KEY

# To point at Grafana Cloud (Tempo), set:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64 instanceID:apikey>
